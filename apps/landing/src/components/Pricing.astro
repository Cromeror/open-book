---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);
const p = dict.pricing;
---

<section id="pricing" class="py-32">
  <div class="mx-auto max-w-7xl px-12 text-center mb-16">
    <h2 class="text-4xl font-bold md:text-5xl"><Fragment set:html={p.title} /></h2>
    <p class="mt-4 text-dark-400">{p.description}</p>
  </div>

  <div class="mx-auto max-w-7xl px-12 overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-dark-700/30">
          <th class="py-8 px-6 text-xl font-bold text-white">{p.capabilities_label}</th>
          {p.tiers.map((tier: any) => (
            <th class="relative py-8 px-6 text-center transition-all duration-300 hover:bg-dark-800/50 hover:shadow-xl">
              {tier.featured && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-mint-400 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-dark-950">
                  {lang === 'es' ? 'Más Popular' : 'Most Popular'}
                </div>
              )}
              <div class="text-2xl font-bold text-white">{tier.name}</div>
              <div class="mt-2 font-mono text-sm text-mint-400">{tier.price}</div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="text-dark-300">
        {p.rows.map((row: any) => (
          <tr class="border-b border-dark-700/10">
            <td class="py-6 px-6 font-medium text-white">{row.feature}</td>
            {row.values.map((val: string) => (
              <td class="py-6 px-6 text-center transition-all duration-300 hover:bg-dark-800/50 hover:shadow-xl">
                {val === 'check' ? (
                  <svg class="mx-auto h-5 w-5 text-mint-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                ) : val === 'cross' ? (
                  <svg class="mx-auto h-5 w-5 text-dark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                ) : (
                  val
                )}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr>
          <td></td>
          {p.tiers.map((tier: any) => (
            <td class="py-8 px-6 text-center transition-all duration-300 hover:bg-dark-800/50 hover:shadow-xl">
              <a
                href="#contact"
                class="inline-block rounded-sm border border-dark-700/30 px-6 py-3 text-xs font-bold uppercase tracking-widest text-dark-200 transition-colors hover:bg-dark-800"
              >
                {tier.cta}
              </a>
            </td>
          ))}
        </tr>
      </tfoot>
    </table>
  </div>
</section>
