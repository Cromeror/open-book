---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);

const icons = [
  `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
];
---

<section id="features" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="text-4xl font-extrabold tracking-tight text-white">{dict.features.title}</h2>

    <div class="mt-16 grid gap-12 md:grid-cols-3">
      {dict.features.pillars.map((p, i) => (
        <div>
          <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-dark-600 bg-dark-800 text-mint-400">
            <Fragment set:html={icons[i]} />
          </div>
          <h3 class="mt-6 text-xl font-bold text-white"><Fragment set:html={p.title} /></h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-300"><Fragment set:html={p.description} /></p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  h3 :global(.dim) {
    color: rgb(var(--color-dark-400, 107 114 128));
  }
</style>
