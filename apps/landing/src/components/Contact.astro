---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);
---

<section id="contact" class="py-24">
  <div class="mx-auto max-w-3xl px-6">
    <div class="overflow-hidden rounded-2xl border border-dark-700 bg-dark-800 p-10 text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-white">{dict.contact.title}</h2>
      <p class="mt-4 text-base text-dark-300">{dict.contact.description}</p>

      <form class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center" action="#" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder={dict.contact.placeholder}
          class="w-full rounded-lg border border-dark-600 bg-dark-700 px-5 py-3 text-sm text-white placeholder-dark-400 focus:border-mint-500 focus:ring-1 focus:ring-mint-500 focus:outline-none sm:w-auto"
        />
        <button
          type="submit"
          class="w-full rounded-lg border border-mint-500 px-6 py-3 text-xs font-semibold uppercase tracking-wider text-mint-400 transition hover:bg-mint-500 hover:text-dark-950 sm:w-auto"
        >
          {dict.contact.cta}
        </button>
      </form>

      <p class="mt-6 text-xs text-dark-400">{dict.contact.disclaimer}</p>
    </div>
  </div>
</section>
